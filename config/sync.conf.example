# Hermes Sync 配置文件
# 路径: ~/.hermes-sync/sync.conf
# 修改后立即生效，无需重启

# ------------------------------------------------------------------
# GitHub Token（三选一，优先级从高到低）
# ------------------------------------------------------------------
# 方式1: 环境变量 export HERMES_SYNC_TOKEN=ghp_xxx
# 方式2: 在此文件设置（不推荐，注意权限）
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# 方式3: ~/.hermes-sync/.github-token 文件

# ------------------------------------------------------------------
# 同步间隔（分钟）
# 用于 systemd 定时器或 crontab
# ------------------------------------------------------------------
SYNC_INTERVAL=30

# ------------------------------------------------------------------
# 冲突处理策略
#   backup    — 备份旧文件后再覆盖（推荐，安全）
#   skip      — 本地有修改时跳过（保守）
#   overwrite — 直接覆盖（激进）
# ------------------------------------------------------------------
CONFLICT_STRATEGY=backup

# ------------------------------------------------------------------
# Git 分支
# ------------------------------------------------------------------
GIT_BRANCH=main

# ------------------------------------------------------------------
# 同步内容（逗号分隔）
# 可用的同步项：
#   profiles     — 角色配置
#   skills       — 自定义技能
#   memories     — 跨会话记忆
#   cron         — 定时任务
#   SOUL.md      — 默认人格
#   config.yaml  — 主配置文件
#   .hermes_history — 命令历史
#   hooks        — 钩子脚本
# ------------------------------------------------------------------
SYNC_ITEMS=profiles,skills,memories,cron,SOUL.md,config.yaml,.hermes_history,hooks

# ------------------------------------------------------------------
# 排除模式（逗号分隔，glob 格式）
# 这些文件/目录不会被同步
# ------------------------------------------------------------------
EXCLUDE_ITEMS=node_modules/,venv/,__pycache__/,*.pyc,.env,*.bak,cache/,audio_cache/,image_cache/,logs/,state.db*,kanban.db*,response_store.db*,gateway.*,processes.json,sessions/,checkpoints/,state-snapshots/

# ------------------------------------------------------------------
# 日志级别
#   0 = 安静（仅错误）
#   1 = 普通（默认）
#   2 = 详细（调试用）
# ------------------------------------------------------------------
LOG_LEVEL=1

# ------------------------------------------------------------------
# 提交信息模板
# 可用变量: {timestamp} {hostname} {user}
# ------------------------------------------------------------------
COMMIT_TEMPLATE=自动同步: {timestamp} [{hostname}]
